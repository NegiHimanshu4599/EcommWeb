@using Ecomm.UI.Common
@using System.IdentityModel.Tokens.Jwt
@inject IHttpContextAccessor HttpContextAccessor
@{
    var token = HttpContextAccessor.HttpContext.Session.GetString("JWT");
    string role = "";
    if (!string.IsNullOrEmpty(token))
    {
        var handler = new JwtSecurityTokenHandler();
        var jwt = handler.ReadJwtToken(token);

        role = jwt.Claims.FirstOrDefault(x => x.Type.Contains("role"))?.Value;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ecomm.UI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/siteHome.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Ecomm.UI.styles.css" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet" />
</head>
<body>
    <!-- NAVBAR -->
    <header>
        <nav class="custom-navbar">
            <div class="nav-left">
                <a class="logo" asp-area="Customer" asp-controller="Home"  asp-action="Index">
                    <i class="fas fa-book-open"></i>
                    <span>BookStore</span>
                </a>
                @if (role == SD.Role_Admin)
                {
                    <ul class="nav-links">
                        <li><a asp-area="Admin" asp-controller="Admin" asp-action="Index">Home</a></li>
                        <li><a href="#">Books</a></li>
                        <li><a href="#">Categories</a></li>
                        <li><a href="#">Deals</a></li>
                        <li><a href="#">New Arrivals</a></li>
                        <li><a asp-area="Admin" asp-controller="Admin" asp-action="Manage">Manage</a></li>
                    </ul>
                }
                else
                {
                    <ul class="nav-links">
                        <li><a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a href="#">Books</a></li>
                        <li><a href="#">Categories</a></li>
                        <li><a href="#">Deals</a></li>
                        <li><a href="#">New Arrivals</a></li>
                    </ul>
                }
            </div>
            <div class="nav-right">
                <div class="search-box">
                    <input type="text" placeholder="Search books..." />
                    <button>
                        <i class="fas fa-search"></i>
                    </button>
                </div>
                <a href="#" class="nav-icon">
                    <i class="far fa-heart"></i>
                    Wishlist
                </a>
                <a href="#" class="nav-icon">
                    <i class="fas fa-shopping-cart"></i>
                    Cart
                </a>
                <partial name="_LoginPartial" />
            </div>
        </nav>
    </header>
    <!-- MAIN -->
    <main>
        @RenderBody()
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
