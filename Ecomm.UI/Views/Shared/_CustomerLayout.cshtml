    <header>
        <nav class="custom-navbar">
            <div class="nav-left">
                <a class="logo" asp-area="Customer" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-book-open"></i>
                    <span>BookStore</span>
                </a>
                @if (role == SD.Role_Admin)
                {
                    <ul class="nav-links">
                        <li>
                            <a asp-area="Admin" asp-controller="Admin" asp-action="Index">
                                Home
                            </a>
                        </li>
                        <li><a href="#">Books</a></li>
                        <li><a href="#">Categories</a></li>
                        <li><a href="#">Deals</a></li>
                        <li><a href="#">New Arrivals</a></li>
                        <li>
                            <a asp-area="Admin" asp-controller="Admin" asp-action="Manage">
                                Manage
                            </a>
                        </li>
                    </ul>
                }
                else
                {
                    <ul class="nav-links">
                        <li>
                            <a asp-area="Customer" asp-controller="Home" asp-action="Index">
                                Home
                            </a>
                        </li>
                        <li><a href="#">Books</a></li>
                        <li><a href="#">Categories</a></li>
                        <li><a href="#">Deals</a></li>
                        <li><a href="#">New Arrivals</a></li>
                    </ul>
                }
            </div>
            <div class="nav-right">
                <div class="search-box">
                    <input type="text" placeholder="Search books..." />
                    <button>
                        <i class="fas fa-search"></i>
                    </button>
                </div>
                <a href="#" class="nav-icon">
                    <i class="far fa-heart"></i>
                    Wishlist
                </a>
                <a asp-area="Customer" asp-controller="Cart" asp-action="Index" class="nav-icon">
                    <i class="fas fa-shopping-cart"></i>
                    Cart
                    @if ((HttpContextAccessor.HttpContext.Session.GetInt32(SD.Ss_CartSessionCount) ?? 0) > 0)
                    {
                        <span class="badge bg-danger">
                            @(HttpContextAccessor.HttpContext.Session.GetInt32(SD.Ss_CartSessionCount))
                        </span>
                    }
                </a>
                <partial name="_LoginPartial" />
            </div>
        </nav>
    </header>
    <main>
        @RenderBody()
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
