@{
    var title = ViewData["Title"] ?? "Admin Dashboard";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - BookStore Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Admin.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.10.16/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/1.1.3/sweetalert.min.css" />
    <link rel="stylesheet"
          href="~/css/responsive.css"
          asp-append-version="true" />
</head>
<body>
    <div class="admin-wrapper">
        <aside class="sidebar" id="sidebar">
            <div class="logo">
                <i class="fas fa-book-open"></i>
                <span>BookStore</span>
            </div>
            <ul class="sidebar-menu">
                <li>
                    <a asp-area="Admin" asp-controller="Admin" asp-action="Index">
                        <i class="fas fa-home"></i>
                        Dashboard
                    </a>
                </li>
                <li class="book-dropdown">
                    <a href="javascript:void(0);" class="book-dropdown-toggle">
                        <div class="menu-title">
                            <i class="fas fa-book"></i>
                            <span>Books</span>
                        </div>
                        <i class="fas fa-chevron-down dropdown-icon"></i>
                    </a>
                    <ul class="book-submenu">
                        <li>
                            <a asp-area="Admin" asp-controller="Book" asp-action="UpsertBook">
                                <i class="fas fa-plus-circle"></i>
                                Add & Modify
                            </a>
                        </li>
                        <li>
                            <a asp-area="Admin"  asp-controller="Book" asp-action="PermanentDelete">
                                <i class="fas fa-trash"></i>
                                Delete
                            </a>
                        </li>
                    </ul>
                </li>
                <li class="book-dropdown">
                    <a href="javascript:void(0);" class="book-dropdown-toggle">
                        <div class="menu-title">
                            <i class="fas fa-layer-group"></i>
                            <span>Categories</span>
                        </div>
                        <i class="fas fa-chevron-down dropdown-icon"></i>
                    </a>
                    <ul class="book-submenu">
                        <li>
                            <a asp-area="Admin" asp-controller="Category" asp-action="UpsertCategory">
                                <i class="fas fa-plus-circle"></i>
                                Add & Modify
                            </a>
                        </li>
                        <li>
                            <a asp-area="Admin" asp-controller="Category" asp-action="PermanentDelete">
                                <i class="fas fa-trash"></i>
                                Delete
                            </a>
                        </li>
                    </ul>
                </li>
                <li class="book-dropdown">
                    <a href="javascript:void(0);" class="book-dropdown-toggle">
                        <div class="menu-title">
                            <i class="fas fa-bookmark"></i>
                            <span>Cover Types</span>
                        </div>
                        <i class="fas fa-chevron-down dropdown-icon"></i>
                    </a>
                    <ul class="book-submenu">
                        <li>
                            <a asp-area="Admin" asp-controller="CoverType" asp-action="UpsertCoverType">
                                <i class="fas fa-plus-circle"></i>
                                Add & Modify
                            </a>
                        </li>
                        <li>
                            <a asp-area="Admin"
                               asp-controller="CoverType"
                               asp-action="PermanentDelete">
                                <i class="fas fa-trash"></i>
                                Delete
                            </a>
                        </li>
                    </ul>
                </li>
                <li>
                    <a href="#">
                        <i class="fas fa-box"></i>
                        Orders
                    </a>
                </li>
                <li>
                    <a asp-area="Admin" asp-controller="Admin" asp-action="GetAllUser">
                        <i class="fas fa-users"></i>
                        Users
                    </a>
                </li>
            </ul>
        </aside>
        <div class="admin-main">
            <div class="topbar">
                <div class="top-left">
                    <button type="button" id="menuToggle" class="btn btn-sm btn-light">
                        <i class="fas fa-bars"></i>
                    </button>
                </div>
                <div class="top-right">
                    <div class="notification-box">
                        <i class="fas fa-bell"></i>
                    </div>
                    <div class="admin-user">
                        <img src="https://i.pravatar.cc/150?img=12" alt="Admin" />
                        <div>
                            <h6 class="mb-0">Admin</h6>
                            <small>Administrator</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="admin-content">
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.js"></script>
    <script src="https://cdn.datatables.net/1.10.16/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
    <script>
        $(document).ready(function () {
            $(".book-dropdown-toggle").click(function () {
                $(this).parent().toggleClass("active");
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>