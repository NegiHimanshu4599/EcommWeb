@model Ecomm.UI.Models.ViewModels.CategoryViewModel
@{
    ViewData["Title"] = "Upsert";
    var title =Model.Category.Id != 0 ? "Update Category": "Add Category";
    var save = Model.Category.Id != 0 ? "Update": "Save";
    Layout = "_AdminLayout";
}
<div class="book-page-bg">
    <div class="admin-card book-card">
        <!-- HEADER -->
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-area="Admin" asp-controller="Admin" asp-action="Manage"class="back-btn">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h2 class="page-title mb-1">
                    @title
                </h2>
                <div class="bread-text">
                    Dashboard /Category /
                    <span>@title</span>
                </div>
            </div>
        </div>
        <!-- FORM -->
        <form method="post">
            <div asp-validation-summary="ModelOnly"class="text-danger">
            </div>
            @if (Model.Category.Id != 0)
            {
                <input type="hidden" asp-for="Category.Id" />
            }
            <div class="row">
                <div class="col-lg-9">
                    <div class="row">
                        <!-- CATEGORY NAME -->
                        <div class="col-md-6 mb-4">
                            <div class="input-group-custom">
                                <div class="input-icon">
                                    <i class="fas fa-book-open"></i>
                                </div>
                                <div class="input-content">
                                    <label asp-for="Category.Name" class="form-label"></label>
                                    <input asp-for="Category.Name" class="form-control custom-input" placeholder="Enter Category Name" />
                                    <span asp-validation-for="Category.Name" class="text-danger"> </span>
                                </div>
                            </div>
                        </div>
                        <!-- PARENT CATEGORY -->
                        <div class="col-md-6 mb-4">
                            <div class="input-group-custom">
                                <div class="input-icon">
                                    <i class="fas fa-layer-group"></i>
                                </div>
                                <div class="input-content">

                                    <label asp-for="Category.ParentCategoryId" class="form-label"></label>
                                    <select asp-for="Category.ParentCategoryId" asp-items="Model.ParentCategories"class="form-select custom-input">
                                        <option value="">
                                            No Parent Category
                                        </option>
                                    </select>
                                    <span asp-validation-for="Category.ParentCategoryId"class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- BUTTONS -->
                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn-admin">
                            <i class="fas fa-save me-2"></i>
                            @save
                        </button>
                        <a asp-area="Admin" asp-controller="Admin" asp-action="Manage" class="btn-outline-admin">
                            <i class="fas fa-arrow-left me-2"></i>
                            BACK TO LIST
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
