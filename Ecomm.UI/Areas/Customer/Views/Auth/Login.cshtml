@using Ecomm.UI.Models.AuthDtos
@model LoginDto
@{
    Layout = "_AuthLayout";
}
<section class="login-container">

    <div class="login-card">

        <div class="corner-shape"></div>

        <!-- LEFT -->
        <div class="login-left">

            <img src="~/images/Loginside.png"
                 class="login-image"
                 alt="Books" />
            <div class="login-overlay">

                <h1>
                    Welcome Back
                    <br />
                    <span>Book Lover!</span>
                </h1>

                <p>
                    Sign in to continue your reading
                    journey with <strong>BookEcomm.</strong>
                </p>

                <div class="feature-list">

                    <div class="feature-row">
                        <div class="feature-icon">
                            <i class="fas fa-book-open"></i>
                        </div>

                        <div>
                            <h6>Wide Collection</h6>
                            <small>
                                Thousands of books across all categories
                            </small>
                        </div>
                    </div>

                    <div class="feature-row">
                        <div class="feature-icon">
                            <i class="fas fa-tags"></i>
                        </div>

                        <div>
                            <h6>Best Prices</h6>
                            <small>
                                Exclusive deals & discounts
                            </small>
                        </div>
                    </div>

                    <div class="feature-row">
                        <div class="feature-icon">
                            <i class="fas fa-truck"></i>
                        </div>

                        <div>
                            <h6>Fast Delivery</h6>
                            <small>
                                Quick and reliable delivery
                            </small>
                        </div>
                    </div>

                </div>

            </div>
        </div>

        <!-- RIGHT -->
        <div class="login-right">

            <div class="form-wrapper">

                <div class="brand-logo">
                    <img src="~/images/logo.png" alt="logo" />
                </div>

                <h2 class="signin-title">
                    Sign In
                </h2>

                <p class="signin-subtitle">
                    Enter your details to access your account
                </p>

                <form method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="mb-3">
                        <label>Email Address</label>
                        <input asp-for="Email"
                               class="form-control custom-input"
                               placeholder="Enter your email" />
                    </div>

                    <div class="mb-3">
                        <label>Password</label>
                        <input asp-for="Password"
                               type="password"
                               class="form-control custom-input"
                               placeholder="Enter your password" />
                    </div>

                    <div class="remember-row">

                        <div>
                            <input type="checkbox" />
                            Remember Me
                        </div>

                        <a href="#" class="forgot-link">
                            Forgot Password?
                        </a>

                    </div>

                    <button type="submit"
                            class="login-btn">
                        Sign In
                    </button>

                </form>

                <div class="divider">
                    <span>or continue with</span>
                </div>

                <div class="social-row">

                    <form asp-controller="Auth"
                          asp-action="ExternalLogin"
                          method="post">

                        <button type="submit"
                                name="provider"
                                value="Google"
                                class="social-btn">

                            <img src="~/images/g-logo.png"
                                 width="20" />

                            Google

                        </button>

                    </form>

                </div>

                <div class="register-link">

                    Don't have an account?

                    <a asp-action="Register">
                        Register Now
                    </a>

                </div>

            </div>

        </div>

    </div>

    <div class="bottom-strip">

        <div class="strip-item">
            🛡️
            <div>
                <strong>Secure Payment</strong>
                <span>100% secure & trusted</span>
            </div>
        </div>

        <div class="strip-item">
            🔄
            <div>
                <strong>Easy Returns</strong>
                <span>30 days return policy</span>
            </div>
        </div>

        <div class="strip-item">
            🎧
            <div>
                <strong>24/7 Support</strong>
                <span>We are here to help</span>
            </div>
        </div>

    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}