@using Ecomm.UI.Common
@model Ecomm.UI.Models.CartDto.CartDto
@{
    Layout = "_CustomerLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/siteCart.css" asp-append-version="true" />
}
<section class="cart-page">
    <div class="page-title-row">
        <div>
            <h1>
                <i class="fas fa-shopping-cart"></i>
                Shopping Cart
            </h1>
            <div class="breadcrumb-area">
                <a asp-area="Customer" asp-controller="Home" asp-action="Index">
                    Home
                </a>
                <span>›</span>
                <span>Cart</span>
            </div>
        </div>
        <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="continue-btn">
            <i class="fas fa-chevron-left"></i>
            Continue Shopping
        </a>
    </div>
    @if (TempData["success"] != null)
    {
        <div class="success-alert">
            <i class="fas fa-check-circle"></i>
            @TempData["success"]
        </div>
    }
    <div class="cart-grid">
        <div class="cart-card">
            <div class="cart-header-row">
                <span>PRODUCT</span>
                <span>PRICE</span>
                <span>QUANTITY</span>
                <span>TOTAL</span>
                <span>ACTION</span>
            </div>
            @foreach (var item in Model.Items)
            {
                <div class="cart-item">
                    <div class="product-info">
                        <img src="@($"{SD.BookBaseUrl}{item.ImageUrl}")" />
                        <div>
                            <h4>@item.ProductName</h4>
                            <p>Paperback</p>
                            <span class="stock">
                                <i class="fas fa-check-circle"></i>
                                In Stock
                            </span>
                        </div>
                    </div>
                    <div class="price">
                        ₹@item.Price
                    </div>
                    <div class="qty">
                        <a asp-action="Minus" asp-route-bookId="@item.BookId">
                            -
                        </a>
                        <span>
                            @item.Quantity
                        </span>
                        <a asp-action="Plus" asp-route-bookId="@item.BookId">
                            +
                        </a>
                    </div>
                    <div class="total">
                        ₹@(item.Price* item.Quantity)
                    </div>
                    <a asp-action="Delete" asp-route-bookId="@item.BookId" class="delete">
                        <i class="fas fa-trash"></i>
                    </a>
                </div>
            }
            <div class="cart-bottom">
                <a asp-action="Clear" class="clear-btn">
                    <i class="fas fa-trash"></i>
                    Clear Cart
                </a>
                <div class="bottom-total">
                    <span>
                        @Model.Items.Sum(x => x.Quantity)
                        Items
                    </span>
                    <strong>
                        Total (MRP):
                        ₹@Model.TotalPrice
                    </strong>
                </div>
            </div>
        </div>
        <div class="summary-card">
            <h3>Order Summary</h3>
            <div class="summary-row">
                <span>
                    Subtotal (@Model.Items.Sum(x => x.Quantity) items)
                </span>
                <span>
                    ₹@Model.TotalPrice
                </span>
            </div>
            <div class="summary-row">
                <span>Shipping Charges</span>
                <span class="green">FREE</span>
            </div>
            <div class="summary-row">
                <span>Discount</span>
                <span class="green">-₹0.00</span>
            </div>
            <hr />
            <div class="grand-total">
                <span>Grand Total</span>
                <span>
                    ₹@Model.TotalPrice
                </span>
            </div>
            <small>
                (Inclusive of all taxes)
            </small>
            <a href="#" class="checkout-btn">
                <i class="fas fa-lock"></i>
                Proceed to Checkout
            </a>
            <a href="#" class="coupon-btn">
                <i class="fas fa-tag"></i>
                Apply Coupon
            </a>
            <div class="summary-footer">
                <span>
                    <i class="far fa-shield-check"></i>
                    Secure Checkout
                </span>
                <span>|</span>
                <span>
                    Easy Returns
                </span>
            </div>
        </div>
    </div>
    <div class="features">
        <div class="feature">
            <i class="fas fa-truck"></i>
            <div>
                <strong>Free Shipping</strong>
                <p>On orders above ₹499</p>
            </div>
        </div>
        <div class="feature">
            <i class="fas fa-undo"></i>
            <div>
                <strong>Easy Returns</strong>
                <p>30 days return policy</p>
            </div>
        </div>
        <div class="feature">
            <i class="fas fa-shield-alt"></i>
            <div>
                <strong>Secure Payment</strong>
                <p>100% secure checkout</p>
            </div>
        </div>
        <div class="feature">
            <i class="fas fa-headset"></i>
            <div>
                <strong>24/7 Support</strong>
                <p>We are here to help</p>
            </div>
        </div>
    </div>
</section>